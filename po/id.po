#: data/org.ayatana.indicator.keyboard.gschema.xml:1
msgid "Show the language icon in desktop mode."
msgstr "Tampilkan ikon bahasa dalam mode desktop."

#: data/org.ayatana.indicator.keyboard.gschema.xml:2
msgid ""
"If enabled, the indicator shows the current layout icon. Otherwise, it "
"displays a generic keyboard icon."
msgstr ""
"Jika diaktifkan, indikator menampilkan ikon tata letak saat ini. Jika tidak, "
"indikator menampilkan ikon papan ketik umum."

#: data/org.ayatana.indicator.keyboard.gschema.xml:3
msgid "Show the language icon in phone mode."
msgstr "Tampilkan ikon bahasa dalam mode ponsel."

#: data/org.ayatana.indicator.keyboard.gschema.xml:4
msgid "Show the language icon in the greeter."
msgstr "Tampilkan ikon bahasa pada layar penyambutan."

#: src/service.c:95
msgid "Keyboard"
msgstr "Papan Ketik"

#: src/service.c:96
msgid "Keyboard layout switcher and settings"
msgstr "Pengalih tata letak papan ketik dan pengaturan"

#: src/service.c:133
msgid "Current keyboard layout"
msgstr "Tata letak papan ketik saat ini"

#: src/service.c:193
msgid "Always show OSK"
msgstr "Selalu tampilkan OSK"

#: src/service.c:199
msgid "Keyboard Settings…"
msgstr "Pengaturan Papan Ketik…"

#: src/service.c:207
msgid "Show Current Layout"
msgstr "Tampilkan Tata Letak Saat Ini"
